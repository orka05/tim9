# Kopiraj ovaj fajl u `.env` i popuni svojim podacima:
#   cp .env.example .env   (ili rucno napravi .env)
#
# Format: postgresql://KORISNIK:LOZINKA@HOST:PORT/IME_BAZE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tim9?schema=public"

# Tajni kljuc za potpisivanje session JWT-a. Generisi svoj sa:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="promeni-me-nasumicnim-stringom"
