// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TrainerRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum TrainerStatus {
  PENDING
  ACTIVE
  BANNED
}

model Trainer {
  id              Int              @id @default(autoincrement())
  name            String
  email           String           @unique
  password        String
  specialty       String           @default("")
  city            String           @default("")
  pricePerSession Int              @default(0)
  rating          Float            @default(1.0)
  status          TrainerStatus    @default(PENDING)
  createdAt       DateTime         @default(now())
  requests        TrainerRequest[]
  exercises       Exercise[]
  trainings       Training[]
}

model Client {
  id        Int              @id @default(autoincrement())
  name      String
  email     String           @unique
  password  String
  createdAt DateTime         @default(now())
  requests  TrainerRequest[]
  trainings Training[]
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model TrainerRequest {
  id          Int                  @id @default(autoincrement())
  message     String               @db.VarChar(1000)
  status      TrainerRequestStatus @default(PENDING)
  clientId    Int
  trainerId   Int
  createdAt   DateTime             @default(now())
  respondedAt DateTime?
  client      Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  trainer     Trainer              @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([trainerId, status, createdAt])
}

enum ExerciseCategory {
  SPRAVA
  REKVIZIT
  BODYWEIGHT
}

model Exercise {
  id          Int              @id @default(autoincrement())
  name        String
  description String           @default("") @db.VarChar(500)
  category    ExerciseCategory @default(SPRAVA)
  videoPath   String?
  trainerId   Int
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  trainer     Trainer          @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  blocks      TrainingBlock[]

  @@index([trainerId, createdAt])
}

model Training {
  id           Int             @id @default(autoincrement())
  title        String          @db.VarChar(120)
  scheduledFor DateTime        @db.Date
  trainerId    Int
  clientId     Int
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  trainer      Trainer         @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  client       Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  blocks       TrainingBlock[]

  @@index([trainerId, scheduledFor])
  @@index([clientId, scheduledFor])
}

model TrainingBlock {
  id          Int      @id @default(autoincrement())
  trainingId  Int
  exerciseId  Int
  position    Int
  sets        Int
  repetitions Int
  restSeconds Int
  notes       String   @default("") @db.VarChar(500)
  training    Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@unique([trainingId, position])
  @@index([exerciseId])
}
