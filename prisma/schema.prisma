// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TrainerRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum TrainerStatus {
  PENDING
  ACTIVE
  BANNED
}

model Trainer {
  id              Int              @id @default(autoincrement())
  name            String
  email           String           @unique
  password        String
  specialty       String           @default("")
  city            String           @default("")
  pricePerMonth   Int              @default(0)
  rating          Float            @default(1.0)
  status          TrainerStatus    @default(PENDING)
  createdAt       DateTime         @default(now())
  requests        TrainerRequest[]
  exercises       Exercise[]
  trainings       Training[]
  reviews         TrainerReview[]
  clientReviews   ClientReview[]
}

model Client {
  id              Int               @id @default(autoincrement())
  name            String
  email           String            @unique
  password        String
  height          Int?
  weight          Int?
  age             Int?
  rating          Float             @default(0)
  createdAt       DateTime          @default(now())
  requests        TrainerRequest[]
  trainings       Training[]
  ownedEquipment  ClientEquipment[]
  customEquipment Equipment[]       @relation("CustomEquipment")
  trainerReviews  TrainerReview[]
  reviews         ClientReview[]
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model TrainerRequest {
  id          Int                  @id @default(autoincrement())
  message     String               @db.VarChar(1000)
  status      TrainerRequestStatus @default(PENDING)
  clientId    Int
  trainerId   Int
  createdAt   DateTime             @default(now())
  respondedAt DateTime?
  client      Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  trainer     Trainer              @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([trainerId, status, createdAt])
}

enum ExerciseCategory {
  SPRAVA
  REKVIZIT
  BODYWEIGHT
}

model Exercise {
  id          Int              @id @default(autoincrement())
  name        String
  description String           @default("") @db.VarChar(500)
  category    ExerciseCategory @default(SPRAVA)
  videoPath   String?
  trainerId   Int
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  trainer     Trainer          @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  blocks      TrainingBlock[]

  @@index([trainerId, createdAt])
}

model Training {
  id           Int             @id @default(autoincrement())
  title        String          @db.VarChar(120)
  scheduledFor DateTime        @db.Date
  trainingRating Int?
  trainingComment String?       @db.VarChar(500)
  trainerId    Int
  clientId     Int
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  trainer      Trainer         @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  client       Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  blocks       TrainingBlock[]

  @@index([trainerId, scheduledFor])
  @@index([clientId, scheduledFor])
}

model TrainingBlock {
  id          Int      @id @default(autoincrement())
  trainingId  Int
  exerciseId  Int
  position    Int
  sets        Int
  repetitions Int
  restSeconds Int
  notes       String   @default("") @db.VarChar(500)
  clientRating Int?
  training    Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@unique([trainingId, position])
  @@index([exerciseId])
}

// Ocena trenera od strane klijenta — jedna po paru (klijent, trener), nezavisna
// od treninga. Prosečna ocena trenera se računa kao AVG(rating) nad ovom tabelom.
model TrainerReview {
  id        Int      @id @default(autoincrement())
  trainerId Int
  clientId  Int
  rating    Int
  comment   String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trainer   Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([trainerId, clientId])
  @@index([trainerId])
}

// Ocena klijenta od strane trenera (kakav je bio u saradnji) — jedna po paru
// (trener, klijent). Prosečna ocena klijenta = AVG(rating) nad ovom tabelom.
model ClientReview {
  id        Int      @id @default(autoincrement())
  clientId  Int
  trainerId Int
  rating    Int
  comment   String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  trainer   Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([trainerId, clientId])
  @@index([clientId])
}


enum EquipmentType {
  SPRAVA
  REKVIZIT
}

// Katalog opreme. `isBase = true` su stavke koje kreira admin i dostupne su svim
// klijentima da ih označe kao svoje. `isBase = false` su custom stavke koje pravi
// klijent (`createdById`) i vidljive su samo njemu. Vlasništvo (koju opremu
// klijent poseduje) modeluje se spojnom tabelom `ClientEquipment`.
model Equipment {
  id          Int               @id @default(autoincrement())
  name        String
  description String            @default("") @db.VarChar(500)
  type        EquipmentType     @default(SPRAVA)
  isBase      Boolean           @default(false)
  createdById Int?
  createdBy   Client?           @relation("CustomEquipment", fields: [createdById], references: [id], onDelete: Cascade)
  owners      ClientEquipment[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([isBase, name])
  @@index([createdById])
}

// Spona „klijent poseduje opremu" (bazna ili sopstvena custom).
model ClientEquipment {
  clientId    Int
  equipmentId Int
  createdAt   DateTime  @default(now())
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@id([clientId, equipmentId])
  @@index([clientId])
}
